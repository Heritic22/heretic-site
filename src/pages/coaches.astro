---
import Layout from '../layouts/Layout.astro';

const coaches = [
  {
    name: "Coach Carolina",
    title: "Brazilian Jiu-Jitsu and Muay Thai",
    image: "/images/coaches/IMG_0352.jpeg",
    bio: "Brown Belt. Focused on fundamentals, control, and real-world application.",
    experience: "10+ years training • Competition experience"
  },
  {
    name: "Coach Justin",
    title: "Brazilian Jiu-Jitsu and Muay Thai",
    image: "/images/coaches/IMG_0353.jpeg",
    bio: "Brown Belt. Focused on fundamentals, control, and real-world application.",
    experience: "10+ years training • Competition experience"
  }
];
---

<Layout title="Coaches">

<!-- HEADER -->
<section style="padding:60px 20px; text-align:center;">
  <h1 style="font-size:48px; font-weight:800;">COACHES</h1>
  <p style="color:#aaa;">Meet the team</p>
</section>

<!-- CENTERED FLEX LAYOUT -->
<section style="
  max-width:1100px;
  margin:0 auto;
  display:flex;
  justify-content:center;
  gap:30px;
  padding:20px;
  flex-wrap:wrap;
">

{coaches.map(coach => (
  <div style="
    background:#0a0a0a;
    border:2px solid #d4af37;
    border-radius:12px;
    overflow:hidden;
    box-shadow:0 0 20px rgba(212,175,55,0.1);
    transition:all 0.2s;
    max-width:480px;
    width:100%;
  "
  onmouseover="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 0 30px rgba(212,175,55,0.3)';"
  onmouseout="this.style.transform=''; this.style.boxShadow='0 0 20px rgba(212,175,55,0.1)';"
  >

    <!-- IMAGE -->
    <img 
      src={coach.image} 
      alt={coach.name}
      style="
        width:100%;
        height:320px;
        object-fit:cover;
        object-position:center 15%;
        border-bottom:2px solid #d4af37;
      "
    />

    <!-- CONTENT -->
    <div style="padding:20px; text-align:left;">

      <h2 style="
        font-size:22px;
        font-weight:700;
        margin-bottom:5px;
      ">
        {coach.name}
      </h2>

      <p style="color:#d4af37; margin-bottom:10px;">
        {coach.title}
      </p>

      <p style="color:#ccc; margin-bottom:12px;">
        {coach.bio}
      </p>

      <p style="font-size:14px; color:#888; margin-bottom:15px;">
        {coach.experience}
      </p>

      <!-- TRAIN BUTTON (CONNECTED TO CONTACT PAGE) -->
      <a href={`/contact?coach=${encodeURIComponent(coach.name)}`}>
        <button style="
          width:100%;
          padding:12px;
          border-radius:8px;
          border:1px solid #d4af37;
          background:#111;
          color:white;
          cursor:pointer;
          transition:all 0.2s;
        "
        onmouseover="this.style.background='#d4af37'; this.style.color='black';"
        onmouseout="this.style.background='#111'; this.style.color='white';"
        >
          Train with {coach.name.split(' ')[1]}
        </button>
      </a>

    </div>

  </div>
))}

</section>

</Layout>