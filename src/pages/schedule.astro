---
import Layout from '../layouts/Layout.astro';

const schedule = [
  {
    day: "Monday",
    classes: [
      { time: "7:30 PM", name: "BJJ (Gi)" },
      { time: "8:30 PM", name: "Muay Thai" }
    ]
  },
  {
    day: "Tuesday",
    classes: [
      { time: "7:30 PM", name: "No-Gi BJJ" },
      { time: "8:30 PM", name: "Muay Thai" }
    ]
  },
  {
    day: "Wednesday",
    classes: [
      { time: "7:30 PM", name: "BJJ (Gi)" },
      { time: "8:30 PM", name: "Muay Thai" }
    ]
  },
  {
    day: "Thursday",
    classes: [
      { time: "7:30 PM", name: "No-Gi BJJ" },
      { time: "8:30 PM", name: "Muay Thai" }
    ]
  }
];
---

<Layout title="Schedule">

<section style="padding: 60px 20px; text-align:center;">
  <h1 style="font-size:48px; font-weight:800; letter-spacing:2px;">
    ADULT SCHEDULE
  </h1>
  <p style="color:#d4af37; margin-top:10px;">
    Click a class below
  </p>
</section>

<section style="max-width:1000px; margin:0 auto; padding:20px; display:grid; grid-template-columns:1fr 1fr; gap:20px;">

  {schedule.map(day => (
    <div style="
      background:#0a0a0a;
      border:2px solid #d4af37;
      border-radius:12px;
      padding:20px;
      box-shadow:0 0 20px rgba(212,175,55,0.1);
    ">

      <h2 style="
        color:#d4af37;
        font-size:20px;
        margin-bottom:15px;
        text-transform:uppercase;
      ">
        {day.day}
      </h2>

      {day.classes.map(cls => (
        <button
          onclick={`window.selectClass('${cls.name}', this)`}
          style="
            width:100%;
            margin-bottom:12px;
            padding:14px;
            border-radius:8px;
            border:1px solid #333;
            background:#111;
            color:white;
            cursor:pointer;
            text-align:left;
            transition:all 0.2s;
          "
          onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 0 12px rgba(212,175,55,0.4)';"
          onmouseout="this.style.transform=''; this.style.boxShadow='';"
        >
          <div style="font-size:12px; color:#aaa;">
            {cls.time}
          </div>
          <div style="font-size:18px; font-weight:600;">
            {cls.name}
          </div>
        </button>
      ))}

    </div>
  ))}

</section>

<section style="max-width:600px; margin:40px auto; padding:20px; text-align:center; border:2px solid #ff0000; border-radius:10px;">
  <h2 style="color:#ff0000; margin-bottom:10px;">
    CLASS DETAILS
  </h2>

  <div id="classDetails">
    <p style="color:#aaa;">Select a class</p>
  </div>
</section>

<script is:inline>
  window.selectClass = function (cls, el) {
    const details = document.getElementById("classDetails");

    document.querySelectorAll("button").forEach(btn => {
      btn.style.outline = "none";
    });

    if (el) {
      el.style.outline = "2px solid #d4af37";
    }

    if (cls === "BJJ (Gi)") {
      details.innerHTML =
        "<h3 style='font-size:24px;'>BJJ (Gi)</h3>" +
        "<p>Gi + Belt required</p>" +
        "<p>Grappling & submissions</p>";
    }

    if (cls === "No-Gi BJJ") {
      details.innerHTML =
        "<h3 style='font-size:24px;'>No-Gi BJJ</h3>" +
        "<p>Rashguard + Shorts</p>" +
        "<p>Fast grappling</p>";
    }

    if (cls === "Muay Thai") {
      details.innerHTML =
        "<h3 style='font-size:24px;'>Muay Thai</h3>" +
        "<p>Training gear</p>" +
        "<p>Striking & conditioning</p>";
    }
  };
</script>

</Layout>