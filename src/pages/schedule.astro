---
import Layout from '../layouts/Layout.astro';

const schedule = [
  {
    day: "Monday",
    classes: [
      { time: "10:00 AM", name: "Adult BJJ" },
      { time: "11:00 AM", name: "Kids BJJ" },
      { time: "7:30 PM", name: "BJJ (Gi)" },
      { time: "8:30 PM", name: "Muay Thai" }
    ]
  },
  {
    day: "Tuesday",
    classes: [
      { time: "10:00 AM", name: "Adult BJJ" },
      { time: "11:00 AM", name: "Kids BJJ" },
      { time: "7:30 PM", name: "No-Gi BJJ" },
      { time: "8:30 PM", name: "Muay Thai" }
    ]
  },
  {
    day: "Wednesday",
    classes: [
      { time: "10:00 AM", name: "Adult BJJ" },
      { time: "11:00 AM", name: "Kids BJJ" },
      { time: "7:30 PM", name: "BJJ (Gi)" },
      { time: "8:30 PM", name: "Muay Thai" }
    ]
  },
  {
    day: "Thursday",
    classes: [
      { time: "10:00 AM", name: "Adult BJJ" },
      { time: "11:00 AM", name: "Kids BJJ" },
      { time: "7:30 PM", name: "No-Gi BJJ" },
      { time: "8:30 PM", name: "Muay Thai" }
    ]
  }
];
---

<Layout title="Schedule">

<section style="padding:60px 20px; text-align:center;">
  <h1 style="font-size:42px; font-weight:800;">SCHEDULE</h1>
  <p style="color:#aaa;">Weekly training times</p>

  <div style="
    width:60px;
    height:2px;
    background:#d4af37;
    margin:20px auto;
  "></div>
</section>

<section style="
  max-width:1100px;
  margin:0 auto;
  display:flex;
  flex-wrap:wrap;
  justify-content:center;
  gap:30px;
  padding:20px;
">

{schedule.map(day => (
  <div style="
    background:#0a0a0a;
    border:2px solid #d4af37;
    border-radius:12px;
    padding:20px;
    width:300px;
    box-shadow:0 0 20px rgba(212,175,55,0.1);
  ">

    <h2 style="color:#d4af37; margin-bottom:15px;">
      {day.day}
    </h2>

    {day.classes.map(cls => (
      <div style="
        margin-bottom:10px;
        padding:10px;
        border:1px solid #333;
        border-radius:6px;
        display:flex;
        justify-content:space-between;
        align-items:center;
      ">

        <div>
          <div style="font-size:12px; color:#888;">
            {cls.time}
          </div>
          <div style="font-weight:600;">
            {cls.name}
          </div>
        </div>

        <div style="
          width:8px;
          height:30px;
          border-radius:4px;
          background:
            {cls.name.includes("Muay") ? "#e50914" :
             cls.name.includes("Kids") ? "#8b5cf6" :
             "#2563eb"};
        "></div>

      </div>
    ))}

  </div>
))}

</section>

</Layout>