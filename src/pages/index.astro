---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Heretic">

<section style="
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  height:80vh;
  text-align:center;
">

  <h1 style="
    font-size:56px;
    font-weight:800;
    letter-spacing:4px;
  ">
    HERETIC
  </h1>

  <p style="
    color:#aaa;
    margin-top:10px;
  ">
    Martial Arts. Discipline. No excuses.
  </p>

  <a href="/contact">
    <button style="
      margin-top:20px;
      padding:14px 28px;
      background:#e50914;
      border:none;
      border-radius:6px;
      color:white;
      font-weight:600;
      cursor:pointer;
    ">
      Book a Free Class
    </button>
  </a>

</section>

</Layout>