---
import '../styles/global.css';
const { title = 'Heretic' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body style="
    background:#000;
    color:white;
    font-family: system-ui, sans-serif;
  ">

    <!-- AZTEC BACKGROUND -->
    <div style="
      position:fixed;
      inset:0;
      background:
        radial-gradient(circle at center, rgba(212,175,55,0.08), transparent 70%),
        url('https://www.transparenttextures.com/patterns/asfalt-dark.png');
      pointer-events:none;
      z-index:-1;
    "></div>

    <!-- NAV -->
    <nav style="
      display:flex;
      justify-content:center;
      gap:40px;
      padding:20px;
      border-bottom:1px solid #222;
    ">
      <a href="/" style="color:#aaa;">Home</a>
      <a href="/coaches" style="color:#aaa;">Coaches</a>
      <a href="/schedule" style="color:#aaa;">Schedule</a>
      <a href="/contact" style="color:#aaa;">Contact</a>
    </nav>

    <main>
      <slot />
    </main>

  </body>
</html>