---
import '../styles/global.css';
const { title = 'Heretic' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="bg-black text-white font-sans">

    <!-- NAVBAR -->
    <nav style="
      display:flex;
      justify-content:center;
      gap:40px;
      padding:20px;
      border-bottom:1px solid #222;
      font-size:14px;
      letter-spacing:1px;
    ">

      <a href="/" style="color:#aaa;">Home</a>
      <a href="/coaches" style="color:#aaa;">Coaches</a>
      <a href="/schedule" style="color:#aaa;">Schedule</a>
      <a href="/contact" style="color:#aaa;">Contact</a>

    </nav>  
        <!-- PAGE CONTENT -->
    <main>
      <slot />
    </main>

  </body>
</html>